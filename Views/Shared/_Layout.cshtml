<!DOCTYPE html>
<html lang="te" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge">

    <title>@ViewData["Title"] - యాదగిరిగుట్ట శ్రీ లక్ష్మీ నరసింహ స్వామి ఆలయం</title>
    <meta name="description" content="యాదగిరిగుట్ట శ్రీ లక్ష్మీ నరసింహ స్వామి ఆలయం – పంచ నరసింహ క్షేత్రం. దర్శనం బుక్ చేయండి, ప్రసాదం ఆర్డర్ చేయండి.">
    <meta name="keywords" content="Yadagirigutta temple, Yadadri temple, Sri Lakshmi Narasimha Swamy, Darshan booking, Telangana pilgrimage">
    <meta name="theme-color" content="#1A0F08">

    <meta property="og:type" content="website">
    <meta property="og:title" content="యాదగిరిగుట్ట శ్రీ లక్ష్మీ నరసింహ స్వామి ఆలయం | Yadagirigutta Temple">
    <meta property="og:image" content="https://s7ap1.scene7.com/is/image/incredibleindia/sri-lakshmi-narasimha-swamy-temple-or-yadadri-temple-or-yadagirigutta-temple-bhongir-telangana-1-attr-hero?qlt=82&wid=1200">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Telugu:wght@300;400;500;600&family=Noto+Serif+Telugu:wght@300;400;600&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/temple.css" asp-append-version="true" />

    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@graph": [
            {
              "@@type": "HinduTemple",
              "@@id": "https://yadagiriguttatemple.telangana.gov.in/#temple",
              "name": "Sri Lakshmi Narasimha Swamy Temple, Yadagirigutta",
              "alternateName": ["Yadadri Temple","Yadagiri Gutta Devasthanam","Pancha Narasimha Kshetram"],
              "description": "A sacred Hindu temple dedicated to Lord Narasimha situated on a hillock in Yadagirigutta, Telangana.",
              "url": "https://yadagiriguttatemple.telangana.gov.in/",
              "address": {
                "@@type": "PostalAddress",
                "streetAddress": "Yadagirigutta",
                "addressLocality": "Yadagirigutta",
                "addressRegion": "Telangana",
                "postalCode": "508115",
                "addressCountry": "IN"
              },
              "geo": {
                "@@type": "GeoCoordinates",
                "latitude": 17.5800,
                "longitude": 78.9740
              },
              "telephone": "+91-08682-265025"
            },
            {
              "@@type": "WebSite",
              "@@id": "https://yadagiriguttatemple.telangana.gov.in/#website",
              "url": "https://yadagiriguttatemple.telangana.gov.in/",
              "name": "Yadagirigutta Temple Official Portal",
              "inLanguage": ["te","en"]
            }
          ]
        }
    </script>
</head>

<body id="page-body">
    <a href="#main-content" class="visually-hidden-focusable p-3 bg-warning text-dark position-absolute" style="z-index: 9999;">
        మెయిన్ కంటెంట్‌కు వెళ్ళండి / Skip to Main Content
    </a>

    <header>
        <nav id="main-nav" role="navigation" aria-label="Primary Navigation">
            <a href="/" class="nav-brand" aria-label="Yadagirigutta Temple Home">
                <div class="nav-chakra" aria-hidden="true">☸</div>
                <div class="nav-brand-text">
                    <span class="nav-brand-te">యాదగిరిగుట్ట</span>
                    <span class="nav-brand-en">Yadagirigutta Temple</span>
                </div>
            </a>

            <ul class="nav-links" role="list">
                <li><a href="#about" data-i18n="nav.about">గురించి</a></li>
                <li><a href="#deities" data-i18n="nav.deities">పంచ నరసింహ</a></li>
                <li><a href="#darshan" data-i18n="nav.darshan">దర్శనం</a></li>
                <li><a href="#prasad" data-i18n="nav.prasad">ప్రసాదం</a></li>
                <li><a href="#timings" data-i18n="nav.timings">సమయాలు</a></li>
                <li><a href="#visit" data-i18n="nav.visit">సందర్శన</a></li>
                <li><a href="#darshan" class="nav-cta-btn" data-i18n="nav.book">సేవ బుక్ చేయండి</a></li>
                <li>
                    <div class="lang-toggle" role="group" aria-label="Language selector">
                        <button type="button" class="lang-btn active" data-lang="te" aria-pressed="true">తె</button>
                        <button type="button" class="lang-btn" data-lang="en" aria-pressed="false">EN</button>
                    </div>
                </li>
            </ul>

            <button class="nav-hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>
        </nav>

        <div class="nav-drawer" id="nav-drawer" role="dialog" aria-modal="true">
            <ul>
                <li><a href="#about" data-i18n="nav.about">గురించి</a></li>
                <li><a href="#deities" data-i18n="nav.deities">పంచ నరసింహ</a></li>
                <li><a href="#darshan" data-i18n="nav.darshan">దర్శనం</a></li>
                <li><a href="#prasad" data-i18n="nav.prasad">ప్రసాదం</a></li>
                <li><a href="#donate" data-i18n="nav.donate">దానం</a></li>
                <li>
                    <div class="lang-toggle" style="display:flex">
                        <button type="button" class="lang-btn" data-lang="te">తె</button>
                        <button type="button" class="lang-btn" data-lang="en">EN</button>
                    </div>
                </li>
            </ul>
        </div>
    </header>

    <div id="main-content" class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 py-4">
        <div class="container text-center">
            <p class="mb-1">© 2026 - యాదగిరిగుట్ట శ్రీ లక్ష్మీ నరసింహ స్వామి దేవస్థానం</p>
            <p class="small">Yadagirigutta Temple Trust - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a></p>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>

    <script src="~/js/temple.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(function() {
            // Initialize Temple logic
            if (window.TempleApp) {
                TempleApp.init();
            }

            // Global AOS (Animation) Settings
            if (typeof AOS !== 'undefined') {
                AOS.init({
                    duration: 1000,
                    easing: 'ease-out-quad',
                    once: true,
                    mirror: false
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>