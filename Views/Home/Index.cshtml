@{
    ViewData["Title"] = "Home Page";
}

<!-- ═══════════════════════════════════════
     LIVE TICKER
═══════════════════════════════════════ -->
<div class="ticker-bar" role="marquee" aria-live="polite" aria-label="Live temple updates">
    <div class="ticker-label">
        <span class="ticker-dot"></span>
        <span data-i18n="ticker.label">నేరుగా</span>
    </div>
    <div style="overflow:hidden;flex:1">
        <div class="ticker-track" id="ticker-track">
            <span class="ticker-item">దర్శన వేచి: సర్వ దర్శనం <strong>~2.5 గంటలు</strong></span>
            <span class="ticker-item">శీఘ్ర దర్శనం <strong>~45 నిమిషాలు</strong></span>
            <span class="ticker-item">ఈరోజు భక్తులు: <strong>48,200+</strong></span>
            <span class="ticker-item">అభిషేకం స్లాట్లు అందుబాటులో ఉన్నాయి</span>
            <span class="ticker-item">ఆన్‌లైన్ బుకింగ్: <strong>తెరిచి ఉంది</strong></span>
            <!-- EN duplicates for seamless loop -->
            <span class="ticker-item">Darshan Wait: Sarva Darshan <strong>~2.5 hrs</strong></span>
            <span class="ticker-item">Sheeghra Darshan <strong>~45 min</strong></span>
            <span class="ticker-item">Today's Pilgrims: <strong>48,200+</strong></span>
            <span class="ticker-item">Abhishekam Slots Available</span>
            <span class="ticker-item">Online Booking: <strong>Open</strong></span>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════
     HERO
═══════════════════════════════════════ -->
<main id="main-content">
    <section id="hero" aria-labelledby="hero-heading">
        <svg class="hero-mandala" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="200" cy="200" r="180" fill="none" stroke="white" stroke-width=".5" />
            <circle cx="200" cy="200" r="140" fill="none" stroke="white" stroke-width=".5" />
            <circle cx="200" cy="200" r="100" fill="none" stroke="white" stroke-width=".5" />
            <circle cx="200" cy="200" r="60" fill="none" stroke="white" stroke-width="1" />
            <circle cx="200" cy="200" r="8" fill="white" />
            <!-- Petals -->
            <g stroke="white" stroke-width=".5" fill="none">
                <ellipse cx="200" cy="130" rx="10" ry="40" transform="rotate(0,200,200)" />
                <ellipse cx="200" cy="130" rx="10" ry="40" transform="rotate(30,200,200)" />
                <ellipse cx="200" cy="130" rx="10" ry="40" transform="rotate(60,200,200)" />
                <ellipse cx="200" cy="130" rx="10" ry="40" transform="rotate(90,200,200)" />
                <ellipse cx="200" cy="130" rx="10" ry="40" transform="rotate(120,200,200)" />
                <ellipse cx="200" cy="130" rx="10" ry="40" transform="rotate(150,200,200)" />
                <ellipse cx="200" cy="130" rx="10" ry="40" transform="rotate(180,200,200)" />
                <ellipse cx="200" cy="130" rx="10" ry="40" transform="rotate(210,200,200)" />
                <ellipse cx="200" cy="130" rx="10" ry="40" transform="rotate(240,200,200)" />
                <ellipse cx="200" cy="130" rx="10" ry="40" transform="rotate(270,200,200)" />
                <ellipse cx="200" cy="130" rx="10" ry="40" transform="rotate(300,200,200)" />
                <ellipse cx="200" cy="130" rx="10" ry="40" transform="rotate(330,200,200)" />
            </g>
            <!-- Outer ornament -->
            <g stroke="white" stroke-width=".3">
                <line x1="200" y1="20" x2="200" y2="380" transform="rotate(0,200,200)" />
                <line x1="200" y1="20" x2="200" y2="380" transform="rotate(45,200,200)" />
                <line x1="200" y1="20" x2="200" y2="380" transform="rotate(90,200,200)" />
                <line x1="200" y1="20" x2="200" y2="380" transform="rotate(135,200,200)" />
            </g>
        </svg>
        <div class="hero-glow-1" aria-hidden="true"></div>
        <div class="hero-glow-2" aria-hidden="true"></div>

        <div class="hero-content">
            <p class="hero-eyebrow" data-i18n="hero.eyebrow">పంచ నరసింహ క్షేత్రం · తెలంగాణ</p>
            <h1 class="hero-title" id="hero-heading">
                శ్రీ లక్ష్మీ<br><em>నరసింహ స్వామి</em>
            </h1>
            <p class="hero-title-en">Sri Lakshmi Narasimha Swamy Temple, Yadagirigutta</p>
            <div class="hero-divider" aria-hidden="true"></div>
            <p class="hero-desc" data-i18n="hero.desc">
                యాదగిరి మహర్షి తపస్సుకు సంతసించి నరసింహ స్వామి ఐదు రూపాలలో ప్రత్యక్షమైన పవిత్ర క్షేత్రం. హైదరాబాద్ నుండి 65 కి.మీ దూరంలో ఉన్న తెలంగాణ యొక్క స్వంత తిరుపతి.
            </p>
            <div class="hero-stats">
                <div class="hero-stat">
                    <span class="hero-stat-num">1 కోటి+</span>
                    <span class="hero-stat-label" data-i18n="hero.stat1">వార్షిక భక్తులు</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-num">₹224 కోట్లు</span>
                    <span class="hero-stat-label" data-i18n="hero.stat2">వార్షిక ఆదాయం</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-num">5</span>
                    <span class="hero-stat-label" data-i18n="hero.stat3">దివ్య రూపాలు</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-num">₹1800 కోట్లు</span>
                    <span class="hero-stat-label" data-i18n="hero.stat4">పునర్నిర్మాణం</span>
                </div>
            </div>
            <div class="hero-btns">
                <a href="#darshan" class="btn-gold" data-i18n="hero.cta1">దర్శనం బుక్ చేయండి</a>
                <a href="#about" class="btn-ghost" data-i18n="hero.cta2">ఆలయం గురించి</a>
            </div>
        </div>
        <div class="hero-scroll-cue" aria-hidden="true">
            <div class="scroll-bar"></div>
            <span>క్రిందకి స్క్రోల్ చేయండి</span>
        </div>
    </section>

    <!-- ═══════════════════════════════════════
         PHOTO STRIP
    ═══════════════════════════════════════ -->
    <div class="photo-strip" role="img" aria-label="Temple photo gallery">

        <div class="photo-tile">
            <img src="/Images/temple1.webp"
                 alt="శ్రీ లక్ష్మీ నరసింహ స్వామి ఆలయం – ముఖ దర్శనం"
                 loading="lazy"
                 onerror="this.style.display='none'">
            <div class="photo-tile-label">శ్రీ లక్ష్మీ నరసింహ స్వామి</div>
        </div>

        <div class="photo-tile">
            <img src="/Images/Temple3.jpg"
                 alt="యాదగిరి గుట్ట పర్వత దర్శనం"
                 loading="lazy"
                 onerror="this.style.display='none'">
            <div class="photo-tile-label">పవిత్ర గుట్ట, తెలంగాణ</div>
        </div>

        <div class="photo-tile">
            <img src="/Images/temple4.webp"
                 alt="యాదగిరిగుట్ట విమాన గోపురం"
                 loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;">
            <div class="photo-tile-label">విమాన గోపురం · కృష్ణ శిల</div>
        </div>

        <div class="photo-tile">
            <img src="/Images/Yadagirigutta_Temple_Main.jpg"
                 alt="యాదగిరిగుట్ట ప్రధాన ఆలయం"
                 loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;">
            <div class="photo-tile-label">యాదగిరిగుట్ట ప్రధాన ఆలయం</div>
        </div>

    </div>

    <!-- ═══════════════════════════════════════
         ABOUT
    ═══════════════════════════════════════ -->
    <section id="about" aria-labelledby="about-heading">
        <div class="section-inner">
            <div class="about-grid">
                <div class="about-img-wrap" data-aos="fade-right" data-aos-duration="800">
                    <img class="about-img"
                         src="/Images/Yadagirigutta_temple.JPG"
                         alt="యాదగిరిగుట్ట ఆలయం – శిల్పకళ వివరం"
                         loading="lazy"
                         onerror="this.parentElement.classList.add('about-img-fallback'); this.remove()">
                    <div class="about-img-border" aria-hidden="true"></div>
                </div>
                <div class="about-text" data-aos="fade-left" data-aos-duration="800">
                    <span class="section-eyebrow" data-i18n="about.eyebrow">చరిత్ర &amp; మహిమ</span>
                    <h2 class="section-title" id="about-heading" data-i18n="about.title">
                        తెలంగాణ యొక్క<br><em>స్వంత తిరుపతి</em>
                    </h2>
                    <p data-i18n="about.p1">
                        త్రేతాయుగంలో మహర్షి ఋష్యశృంగుని కుమారుడైన యాద మహర్షి ఈ గుట్టపై తపస్సు చేయగా, శ్రీ నరసింహ స్వామి ఐదు దివ్య రూపాలలో దర్శనమిచ్చారు. ఈ క్షేత్రాన్ని <strong>పంచ నరసింహ క్షేత్రం</strong>గా పిలుస్తారు.
                    </p>
                    <p data-i18n="about.p2">
                        కృష్ణ శిల (నల్ల రాయి) తో నిర్మించిన ఈ ఆలయం 2016–2022 మధ్య ₹1,800 కోట్ల వ్యయంతో పునర్నిర్మించబడింది. ద్రావిడ మరియు కాకతీయ శైలుల సమ్మేళనంలో నిర్మించిన సువర్ణ విమాన గోపురం 6 కి.మీ దూరం నుండి కనిపిస్తుంది.
                    </p>
                    <p data-i18n="about.p3">
                        ప్రతి సంవత్సరం 1 కోటి భక్తులు సందర్శించే ఈ ఆలయం, 2025 నాటి తెలంగాణ ధర్మదాయ సంస్థ చట్టం ప్రకారం యాదగిరిగుట్ట ఆలయ ట్రస్ట్ బోర్డు (YTD) ద్వారా నిర్వహించబడుతోంది.
                    </p>
                    <div class="fact-row">
                        <div class="fact-item">
                            <span class="fact-num">65 కి.మీ</span>
                            <div class="fact-label" data-i18n="about.fact1">హైదరాబాద్ నుండి</div>
                        </div>
                        <div class="fact-item">
                            <span class="fact-num">14 ఎకరాలు</span>
                            <div class="fact-label" data-i18n="about.fact2">ఆలయ సముదాయం</div>
                        </div>
                        <div class="fact-item">
                            <span class="fact-num">104 చ.కి.మీ</span>
                            <div class="fact-label" data-i18n="about.fact3">ఆలయ నగర ప్రాంతం</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════
         PANCHA NARASIMHA
    ═══════════════════════════════════════ -->
    <section id="deities" aria-labelledby="deities-heading">
        <div class="section-inner">
            <div data-aos="fade-up">
                <span class="section-eyebrow section-eyebrow--light" data-i18n="deities.eyebrow">ఐదు దివ్య అవతారాలు</span>
                <h2 class="section-title section-title--light" id="deities-heading" data-i18n="deities.title">
                    పంచ నరసింహ — <em>దివ్య రూపాలు</em>
                </h2>
            </div>
            <div class="pancha-grid">
                <!-- 1 -->
                <article class="pancha-card" data-aos="fade-up" data-aos-delay="0" tabindex="0"
                         aria-label="జ్వాల నరసింహుడు">
                    <span class="pancha-num">01</span>
                    <div class="pancha-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M12 2C9.5 5 7 7 7 10.5A5 5 0 0012 15.5 5 5 0 0017 10.5C17 7 14.5 5 12 2zM10 20h4v2h-4z" /></svg>
                    </div>
                    <span class="pancha-name-te">జ్వాల నరసింహుడు</span>
                    <span class="pancha-name-en">Jwala Narasimha</span>
                    <div class="pancha-meaning" data-i18n="pancha.fire">జ్వాలారూపం</div>
                    <p class="pancha-desc" data-i18n="pancha.p1">అగ్ని జ్వాల రూపంలో ప్రత్యక్షమైన ఆది రూపం. సర్పాకార అగ్నిలో భక్తులను రక్షించే శక్తివంతమైన అవతారం.</p>
                </article>
                <!-- 2 -->
                <article class="pancha-card" data-aos="fade-up" data-aos-delay="80" tabindex="0"
                         aria-label="యోగానంద నరసింహుడు">
                    <span class="pancha-num">02</span>
                    <div class="pancha-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M12 2C9 2 7 4 7 7c0 2 1 3.5 2.5 4.5V15h5v-3.5C16 10.5 17 9 17 7c0-3-2-5-5-5zM10 18h4v2h-4z" /></svg>
                    </div>
                    <span class="pancha-name-te">యోగానంద నరసింహుడు</span>
                    <span class="pancha-name-en">Yogananda Narasimha</span>
                    <div class="pancha-meaning" data-i18n="pancha.yoga">యోగ రూపం</div>
                    <p class="pancha-desc" data-i18n="pancha.p2">ధ్యాన మగ్నమైన యోగ భంగిమలో ఉన్న శాంత రూపం. మనశ్శాంతి మరియు జ్ఞాన ప్రాప్తికి సేవించే రూపం.</p>
                </article>
                <!-- 3 -->
                <article class="pancha-card" data-aos="fade-up" data-aos-delay="160" tabindex="0"
                         aria-label="గండభేరుండ నరసింహుడు">
                    <span class="pancha-num">03</span>
                    <div class="pancha-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M12 2l-4 7H4l6 4-2 7 4-3 4 3-2-7 6-4h-4z" /></svg>
                    </div>
                    <span class="pancha-name-te">గండభేరుండ నరసింహుడు</span>
                    <span class="pancha-name-en">Gandabherunda Narasimha</span>
                    <div class="pancha-meaning" data-i18n="pancha.invincible">అజేయ రూపం</div>
                    <p class="pancha-desc" data-i18n="pancha.p3">రెండు తలల దివ్య పక్షి రూపం. గుహలో సహజంగా ఏర్పడిన పగుళ్లలో వెలసిన ప్రత్యేక రూపం.</p>
                </article>
                <!-- 4 -->
                <article class="pancha-card" data-aos="fade-up" data-aos-delay="240" tabindex="0"
                         aria-label="ఉగ్ర నరసింహుడు">
                    <span class="pancha-num">04</span>
                    <div class="pancha-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M12 2L2 7v5c0 5.55 4.18 10.74 10 12 5.82-1.26 10-6.45 10-12V7L12 2zm0 4l6 3v4c0 3.6-2.6 7-6 8.2C8.6 20 6 16.6 6 13V9l6-3z" /></svg>
                    </div>
                    <span class="pancha-name-te">ఉగ్ర నరసింహుడు</span>
                    <span class="pancha-name-en">Ugra Narasimha</span>
                    <div class="pancha-meaning" data-i18n="pancha.fierce">ఉగ్ర రక్షకుడు</div>
                    <p class="pancha-desc" data-i18n="pancha.p4">అత్యంత భయంకరమైన రూపం. అసురులను, చెడుశక్తులను నాశనం చేసే అవతారం. కష్టాల నివారణకు ఆరాధించే రూపం.</p>
                </article>
                <!-- 5 -->
                <article class="pancha-card" data-aos="fade-up" data-aos-delay="320" tabindex="0"
                         aria-label="లక్ష్మీ నరసింహుడు">
                    <span class="pancha-num">05</span>
                    <div class="pancha-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z" /></svg>
                    </div>
                    <span class="pancha-name-te">లక్ష్మీ నరసింహుడు</span>
                    <span class="pancha-name-en">Lakshmi Narasimha</span>
                    <div class="pancha-meaning" data-i18n="pancha.benevolent">కరుణామయ రూపం</div>
                    <p class="pancha-desc" data-i18n="pancha.p5">లక్ష్మీ దేవి తన ఒడిలో కూర్చున్న శాంత రూపం. ప్రధాన విగ్రహం. సకల శుభాలు, సంపదలు ప్రసాదించే ముఖ్యమైన అవతారం.</p>
                </article>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════
         DARSHAN BOOKING
    ═══════════════════════════════════════ -->
    <section id="darshan" aria-labelledby="darshan-heading">
        <div class="section-inner">
            <span class="section-eyebrow" data-i18n="darshan.eyebrow">డిజిటల్ సేవా బుకింగ్</span>
            <h2 class="section-title" id="darshan-heading" data-i18n="darshan.title">
                దర్శనం &amp; <em>సేవ బుక్ చేయండి</em>
            </h2>
            <div class="live-pill">
                <span class="ticker-dot"></span>
                <span data-i18n="darshan.live">నేరుగా వేచి: సర్వ దర్శనం ~2.5 గంటలు · శీఘ్ర దర్శనం ~45 నిమి</span>
            </div>

            <div class="booking-grid">
